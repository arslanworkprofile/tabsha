# Frontend environment variables
# For local development, the proxy in package.json handles /api → http://localhost:5000
# For production, set this to your deployed backend URL:
REACT_APP_API_URL=https://tabsha-production.up.railway.app/api

# Stripe publishable key (optional — get from stripe.com dashboard)
# REACT_APP_STRIPE_KEY=pk_test_your_publishable_key_here
